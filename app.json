{
  "name": "Boulder Competition API",
  "description": "API service for the Bouldering Festival Competition app, providing score calculation and 27crags data scraping capabilities.",
  "repository": "https://github.com/dimispapa/boulder-comp-api",
  "keywords": ["python", "fastapi", "celery", "redis", "sqlmodel", "neon"],
  "addons": ["heroku-redis:hobby-dev"],
  "env": {
      "NEON_DB_URL": {
        "description": "Your Neon DB connection URL",
        "required": true
      },
    "DEV_ENV": {
      "description": "Whether the app is running in dev mode",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "eco"
    },
    "worker": {
      "quantity": 1,
      "size": "eco"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
} 