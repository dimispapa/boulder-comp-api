digraph G {
    rankdir=LR;
    node [shape=record, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];
    
    /* Styling */
    graph [splines=ortho, nodesep=0.7, ranksep=1.3];
    
    /* Entity Nodes */
    crags [label="{crags|id: UUID\lname: text\ldisplay_name: text\ldescription: text\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    sectors [label="{sectors|id: UUID\lname: text\ldisplay_name: text\lcrag_id: UUID\ldescription: text\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    boulders [label="{boulders|id: UUID\lname: text\ldisplay_name: text\lsector_id: UUID\lurl: text\lgps_postgis: GEOGRAPHY(POINT)\lgps_string: text\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    boulder_photos [label="{boulder_photos|id: UUID\lboulder_id: UUID\lsource_url: text\lorder: int\lphoto_id: text\lstorage_url: text\llines_data: JSONB\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    routes [label="{routes|id: UUID\lboulder_id: UUID\lname: text\ldisplay_name: text\lurl: text\lgrade: text\lrating: float\ldescription: text\lline_data: JSONB\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    boulder_sector_mappings [label="{boulder_sector_mappings|id: UUID\lboulder_url: text\lsector_name: text\lsector_id: UUID\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    competitions [label="{competitions|id: UUID\lname: text\lcrag_id: UUID\ldisplay_name: text\lcategory: text[]\lstart_date: date\lend_date: date\lstatus: enum\ldescription: text\lvenue: text\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    teams [label="{teams|id: UUID\lcompetition_id: UUID\lname: text\lcaptain_id: UUID\lcategory: text\lpaid: boolean\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    participants [label="{participants|id: UUID\lcompetition_id: UUID\lfirst_name: text\llast_name: text\lemail: text\lteam_id: UUID\lsolo_entry: boolean\lclub_member: boolean\lmembership_number: text\lpaid: boolean\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    ascents [label="{ascents|id: UUID\lcompetition_id: UUID\lparticipant_id: UUID\lroute_id: UUID\ltimestamp: timestamp\lsubmitted: boolean\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    scored_ascents [label="{scored_ascents|id: UUID\lascent_id: UUID\lparticipant_id: UUID\lroute_id: UUID\lbase_points: float\lvolume_bonus: float\lunique_bonus: float\ltotal_points: float\ltimestamp: timestamp\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    marathon_rankings [label="{marathon_rankings|id: UUID\lcompetition_id: UUID\lteam_id: UUID\lbase_score: float\lvolume_score: float\lunique_ascent_score: float\lteam_ascent_bonus: float\lmaster_grade_bonus: float\ltotal_score: float\lrank: integer\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    boulder_beasts_rankings [label="{boulder_beasts_rankings|id: UUID\lcompetition_id: UUID\lparticipant_id: UUID\ltop_grades: text[]\ltotal_score: float\lrank: integer\lcreated_at: timestamp\lupdated_at: timestamp}"];
    
    base_points [label="{base_points|grade: text\lpoints: integer\lincrement_factor: float}"];
    
    volume_bonus [label="{volume_bonus|bonus_increment: integer\lpoints_per_increment: integer}"];
    
    unique_ascent_bonus [label="{unique_ascent_bonus|bonus_factor: float}"];
    
    team_ascent_bonus [label="{team_ascent_bonus|team_size: integer\lbonus_factor: float}"];
    
    master_grade_bonus [label="{master_grade_bonus|bonus_factor: float}"];
    
    /* Entity Relationships */
    crags -> sectors [label="crag_id", len=1.5];
    sectors -> boulders [label="sector_id", len=1.5];
    boulders -> boulder_photos [label="boulder_id", len=1.5];
    boulders -> routes [label="boulder_id", len=1.5];
    sectors -> boulder_sector_mappings [label="sector_id", len=1.5];
    
    crags -> competitions [label="crag_id", len=1.5];
    competitions -> teams [label="competition_id", len=1.5];
    competitions -> participants [label="competition_id", len=1.5];
    teams -> participants [label="team_id", len=1.5];
    
    competitions -> ascents [label="competition_id", len=1.5];
    participants -> ascents [label="participant_id", len=1.5];
    routes -> ascents [label="route_id", len=1.5];
    
    ascents -> scored_ascents [label="ascent_id", len=1.5];
    participants -> scored_ascents [label="participant_id", len=1.5];
    routes -> scored_ascents [label="route_id", len=1.5];
    
    competitions -> marathon_rankings [label="competition_id", len=1.5];
    teams -> marathon_rankings [label="team_id", len=1.5];
    
    competitions -> boulder_beasts_rankings [label="competition_id", len=1.5];
    participants -> boulder_beasts_rankings [label="participant_id", len=1.5];
    
    /* Scoring config references (subtle dashed edges) */
    base_points -> scored_ascents [color="gray", style="dashed", constraint=false];
    volume_bonus -> scored_ascents [color="gray", style="dashed", constraint=false];
    unique_ascent_bonus -> scored_ascents [color="gray", style="dashed", constraint=false];
    
    base_points -> marathon_rankings [color="gray", style="dashed", constraint=false];
    volume_bonus -> marathon_rankings [color="gray", style="dashed", constraint=false];
    unique_ascent_bonus -> marathon_rankings [color="gray", style="dashed", constraint=false];
    team_ascent_bonus -> marathon_rankings [color="gray", style="dashed", constraint=false];
    master_grade_bonus -> marathon_rankings [color="gray", style="dashed", constraint=false];
    
    base_points -> boulder_beasts_rankings [color="gray", style="dashed", constraint=false];
    
    /* Subgraphs for logical grouping */
    subgraph cluster_boulder_data {
        label = "Bouldering Data";
        color = lightblue;
        style = filled;
        node [style=filled, fillcolor=white];
        crags; sectors; boulders; boulder_photos; routes; boulder_sector_mappings;
    }
    
    subgraph cluster_competition {
        label = "Competition Data";
        color = lightgreen;
        style = filled;
        node [style=filled, fillcolor=white];
        competitions; teams; participants; ascents;
    }
    
    subgraph cluster_scoring {
        label = "Scoring Data";
        color = lightyellow;
        style = filled;
        node [style=filled, fillcolor=white];
        scored_ascents; marathon_rankings; boulder_beasts_rankings;
    }
    
    subgraph cluster_scoring_config {
        label = "Scoring Configuration";
        color = lightpink;
        style = filled;
        node [style=filled, fillcolor=white];
        base_points; volume_bonus; unique_ascent_bonus; team_ascent_bonus; master_grade_bonus;
    }
} 